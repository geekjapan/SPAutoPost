# SPAutoPost hosted 実行用 環境変数 / Secret 参照サンプル（PLACEHOLDER のみ）。
#
# !! 実値を書かないこと。実値はこのファイルに置かず、Azure Container Apps の secret
#    ref（Key Vault / Container Apps secrets）から環境変数として注入する。
# このファイルは「どの env / secret が必要か」を示す参照例で、コミット可能なのは
# placeholder だけ。config の env:NAME 参照（deploy/config.hosted.example.yml）と対応する。

# --- 非機密（plain env として設定可） ---
SPAUTOPOST_ENV=production

# --- Secret（Container Apps secret ref 経由で注入。値はここに書かない） ---
# PostgreSQL 接続文字列（storage.database_url = env:SPAUTOPOST_DATABASE_URL）
SPAUTOPOST_DATABASE_URL=postgresql://USER:__SECRET__@HOST:5432/spautopost

# Entra ID テナント（sharepoint.tenant_id = env:SPAUTOPOST_TENANT_ID）
SPAUTOPOST_TENANT_ID=__SECRET__

# SharePoint 投稿先（sharepoint.site_id / page_library_id）
SPAUTOPOST_SHAREPOINT_SITE_ID=__SECRET__
SPAUTOPOST_SHAREPOINT_PAGE_LIBRARY_ID=__SECRET__

# --- Optional（該当 source を有効化する場合のみ） ---
# SPAUTOPOST_NVD_API_KEY=__SECRET__
