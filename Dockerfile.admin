FROM node:22-bookworm-slim AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY admin-api ./admin-api
RUN npm run admin-api:build

FROM node:22-bookworm-slim

ENV NODE_ENV=production \
    PORT=3000

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY --from=build /app/admin-api/dist ./admin-api/dist

EXPOSE 3000
CMD ["node", "admin-api/dist/src/main.js"]
